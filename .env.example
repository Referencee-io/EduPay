# Copia este archivo como .env y ajusta los valores.
# Los secretos NUNCA se suben al repositorio (instrucciones sección 12).

# Base de datos (coincide con docker-compose.yml para desarrollo local)
DATABASE_URL="postgresql://plataforma:plataforma_dev@localhost:5432/pagos_escolares?schema=public"

# Redis para BullMQ (Fase 2)
REDIS_URL="redis://localhost:6379"

# Correo de desarrollo (MailHog)
SMTP_HOST="localhost"
SMTP_PORT="1025"

# Entorno
NODE_ENV="development"
